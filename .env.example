# Vulnex environment configuration
#
# Quick start:
#   cp .env.example .env
#   docker compose up
#
# These defaults are intentionally working values for a local demo so
# `docker compose up` boots without editing anything. ROTATE every secret
# below before deploying anywhere a stranger can reach.

# ── Django core ─────────────────────────────────────────────────────────
# Dev-only key (do NOT use in production). Generate a real one with:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=dev-insecure-key-change-me-before-deploying-anywhere

# DEBUG=True bypasses VAULT_MASTER_KEY enforcement and gives verbose errors.
# Flip to False in any deployment a stranger can reach.
DJANGO_DEBUG=True

DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_USE_HTTPS=False
SITE_URL=http://localhost:8000

# ── Database (Docker Compose injects this; uncomment for native runs) ───
# DATABASE_URL=postgres://vulnex:vulnex@localhost:5432/vulnex

# ── Credentials vault key ───────────────────────────────────────────────
# REQUIRED in production. Encrypts the credentials vault at rest.
# Optional in DEBUG (falls back to a SECRET_KEY-derived key with a warning).
# Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Rotate with: python manage.py rotate_vault_key --old-key <old> --new-key <new>
#VAULT_MASTER_KEY=

# ── Bootstrap superuser (created on first compose up if no superuser exists) ──
DJANGO_BOOTSTRAP_USERNAME=admin
DJANGO_BOOTSTRAP_PASSWORD=admin1
DJANGO_BOOTSTRAP_EMAIL=admin@example.com

# ── Demo data ───────────────────────────────────────────────────────────
# When 1/true, the entrypoint runs `python manage.py seed_demo` on boot to
# populate a demo client, two engagements, four demo users, eight findings,
# placeholder evidence, recon hosts, an attack-path DAG, activity logs, and
# one generated PDF. Idempotent — re-running is a no-op once the data is in.
# Set to 0 for a clean install.
SEED_DEMO=1

# ── Showcase mode (public live demo) ────────────────────────────────────
# Only enable for the public demo deployment (e.g. fly.io). When True:
#   * a "Public demo · resets hourly · do not enter real data" banner is
#     rendered on every page,
#   * outbound email is silenced (locmem backend — invitations / password
#     resets stay in memory and never reach a real inbox),
#   * new admin user creation and new API key issuance are blocked at the
#     middleware layer (clients can still browse / file findings),
#   * Celery beat resets the database every hour (requires a real broker —
#     CELERY_BROKER_URL must point at Redis, NOT memory://).
SHOWCASE_MODE=False

# ── Email (console backend prints to terminal in dev) ───────────────────
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
# For real email (e.g. Gmail with App Password):
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=app-gmail@gmail.com
# EMAIL_HOST_PASSWORD=your-app-password
# DEFAULT_FROM_EMAIL=Vulnex <noreply@vulnex.local>

# ── Celery (Docker Compose injects these; uncomment for native runs) ────
# CELERY_BROKER_URL=redis://localhost:6379/0
# CELERY_RESULT_BACKEND=redis://localhost:6379/0
