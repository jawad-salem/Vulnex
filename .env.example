# REQUIRED. Generate with:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
SITE_URL=http://localhost:8000

# REQUIRED in production. Encrypts the credentials vault at rest.
# Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Optional in DEBUG (falls back to a SECRET_KEY-derived key with a warning).
# Rotate with: python manage.py rotate_vault_key --old-key <old> --new-key <new>
VAULT_MASTER_KEY=

# Email (console backend prints to terminal in dev)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
# For real email (e.g. Gmail with App Password):
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=app-gmail@gmail.com
# EMAIL_HOST_PASSWORD=your-app-password (generate in Gmail settings)
# DEFAULT_FROM_EMAIL=Vulnex <noreply@vulnex.local>

# Database (leave empty for SQLite)
# DATABASE_URL=postgres://user:pass@localhost:5432/vulnex
