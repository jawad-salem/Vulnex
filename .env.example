DJANGO_SECRET_KEY=change-me-to-a-random-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=*
SITE_URL=http://localhost:8000

# Email (console backend prints to terminal in dev)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
# For real email (e.g. Gmail with App Password):
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=your-email@gmail.com
# EMAIL_HOST_PASSWORD=your-app-password
# DEFAULT_FROM_EMAIL=PentestFlow <noreply@pentestflow.local>

# Database (leave empty for SQLite)
# DATABASE_URL=postgres://user:pass@localhost:5432/pentestflow
